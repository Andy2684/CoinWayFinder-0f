FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY tsconfig.json ./

# Install dependencies
RUN npm ci --only=production

# Copy source code
COPY lib/ ./lib/
COPY scripts/ ./scripts/

# Build TypeScript
RUN npm run build

# Expose port for health checks
EXPOSE 3001

# Start the scheduler
CMD ["node", "dist/scripts/start-bot-scheduler.js"]
