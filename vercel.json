{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/bots/scheduler",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "regions": ["iad1"],
  "framework": "nextjs"
}
