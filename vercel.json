{
  "buildCommand": "npm install --force && npm run build",
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/bots/scheduler",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "NPM_CONFIG_FORCE": "true"
  },
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
